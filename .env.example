# Copy this to .env and fill in your FICO credentials.
# For Vercel: add these as Environment Variables in the Vercel project dashboard.

# FICO Decision Manager endpoint (full external URL)
VITE_DM_ENDPOINT_URL=
# FICO IAM token endpoint (full external URL)
VITE_DM_TOKEN_URL=
# FICO client credentials
VITE_DM_CLIENT_ID=your_client_id
VITE_DM_CLIENT_SECRET=your_client_secret

# Proxy paths - leave as-is (Vite proxies in dev, Vercel functions in prod)
VITE_DM_PROXY_URL=/api/dm
VITE_DM_TOKEN_PROXY_URL=/api/token

# Minimum ms to show the loading screen
VITE_EVALUATION_LOADING_MIN_MS=1500

# Source platform tag sent with every order
VITE_SOURCE_PLATFORM=MYNTRA
